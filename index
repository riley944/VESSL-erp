async function submitCreatePO() {
  const factory = $id('po-factory').value;
  const num     = $id('po-num').value.trim();
  if (!factory || !num) { alert('Factory and PO number are required.'); return; }
  const po = {
    factory_company_id: factory,
    order_number: num,
    order_date: $id('po-date').value||now_date(),
    requested_ship_date: $id('po-ship').value||null,
    incoterm: $id('po-inco').value.trim()||null,
    payment_terms: $id('po-pay').value.trim()||null,
    deposit_percent: Number($id('po-dep').value)||null,
    mold_fee: Number($id('po-mold').value)||0,
    sample_fee: Number($id('po-sample').value)||0,
    currency: $id('po-cur').value||'USD',
    notes: $id('po-notes').value.trim()||null,
    status: 'draft'
  };
  const { data: created, error } = await SB.from('purchase_orders').insert(po).select().single();
  if (error) { alert('Error creating PO: '+error.message); return; }
  const rows = $id('items-body').querySelectorAll('tr');
  for (const row of rows) {
    const idx = row.id.replace('item-row-','');
    const prodId = document.getElementById('item-prod-'+idx)?.value;
    const qty = Number(document.getElementById('item-qty-'+idx)?.value||0);
    const price = Number(document.getElementById('item-price-'+idx)?.value||0);
    if (prodId && qty>0) {
      await SB.from('purchase_order_items').insert({ purchase_order_id:created.id, product_id:prodId, quantity:qty, unit_price:price, currency:po.currency });
    }
  }
  hideModal();
  navigate('order-detail',{id:created.id});
}

