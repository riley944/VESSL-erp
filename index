<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vessl — KUI Operations</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Spline+Sans:wght@400;500;600&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--ink:#111827;--accent:#1f5e4f;--border:#e5e7eb;--muted:#6b7280;--soft:#f9fafb;--card:#ffffff;--serif:'Fraunces',serif;--sans:'Spline Sans',sans-serif;--mono:'Spline Sans Mono',monospace;}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:var(--sans);font-size:14px;color:var(--ink);background:var(--soft);}
/* LOGIN */
#login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--soft);}
.login-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:48px 40px;width:380px;text-align:center;}
.login-card img{height:36px;margin:0 auto 28px;}
.login-card h2{font-family:var(--serif);font-weight:400;font-size:22px;margin-bottom:28px;}
.login-field{width:100%;padding:11px 14px;border:1px solid var(--border);border-radius:6px;font-family:var(--sans);font-size:14px;margin-bottom:12px;outline:none;transition:border-color .15s;}
.login-field:focus{border-color:var(--ink);}
.btn-primary{width:100%;padding:11px;background:var(--ink);color:#fff;border:none;border-radius:6px;font-family:var(--sans);font-size:14px;font-weight:500;cursor:pointer;margin-top:4px;letter-spacing:.02em;}
.btn-primary:hover{background:#1f2937;}
.login-error{color:#dc2626;font-size:13px;margin-top:12px;min-height:18px;}
/* APP SHELL */
#app{display:flex;height:100vh;overflow:hidden;}
/* SIDEBAR */
#sidebar{width:220px;background:var(--ink);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;}
.sb-logo{padding:24px 20px 20px;border-bottom:1px solid rgba(255,255,255,.08);}
.sb-logo img{height:30px;width:auto;filter:brightness(0) invert(1);}
.sb-section{padding:12px 12px 0;font-family:var(--mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px;}
.nav-link{display:flex;align-items:center;gap:10px;padding:9px 14px;border-radius:6px;margin:1px 8px;color:rgba(255,255,255,.6);font-size:13.5px;font-weight:400;cursor:pointer;transition:all .12s;user-select:none;}
.nav-link:hover{color:#fff;background:rgba(255,255,255,.07);}
.nav-link.active{color:#fff;background:rgba(255,255,255,.12);}
.nav-link svg{width:16px;height:16px;flex-shrink:0;opacity:.7;}
.nav-link.active svg{opacity:1;}
.sb-spacer{flex:1;}
.sb-user{padding:16px 12px;border-top:1px solid rgba(255,255,255,.08);}
.sb-email{font-size:11.5px;color:rgba(255,255,255,.45);display:block;margin-bottom:10px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.btn-signout{width:100%;padding:8px;background:rgba(255,255,255,.07);color:rgba(255,255,255,.6);border:none;border-radius:5px;font-family:var(--sans);font-size:12.5px;cursor:pointer;letter-spacing:.02em;}
.btn-signout:hover{background:rgba(255,255,255,.12);color:#fff;}
/* MAIN */
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
#page-header{padding:20px 32px;background:var(--card);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
#page-title{font-family:var(--serif);font-weight:400;font-size:24px;}
#page-action{display:flex;gap:10px;}
#page-content{flex:1;overflow-y:auto;padding:28px 32px;}
/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border-radius:6px;font-family:var(--sans);font-size:13.5px;font-weight:500;cursor:pointer;border:none;letter-spacing:.01em;transition:all .12s;}
.btn-dark{background:var(--ink);color:#fff;}
.btn-dark:hover{background:#1f2937;}
.btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--border);}
.btn-ghost:hover{background:var(--soft);}
.btn-sm{padding:6px 12px;font-size:12.5px;}
.btn-danger{background:#fee2e2;color:#dc2626;}
.btn-danger:hover{background:#fecaca;}
.btn-green{background:#d1fae5;color:#065f46;}
.btn-green:hover{background:#a7f3d0;}
/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:20px 22px;}
.stat-label{font-family:var(--mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;}
.stat-value{font-family:var(--mono);font-size:28px;font-weight:500;}
.stat-sub{font-size:12px;color:var(--muted);margin-top:4px;}
/* SECTION CARD */
.section-card{background:var(--card);border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.section-head{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.section-head h3{font-size:14px;font-weight:600;}
/* TABLE */
.data-table{width:100%;border-collapse:collapse;}
.data-table th{font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);text-align:left;padding:11px 16px;border-bottom:1px solid var(--border);font-weight:400;white-space:nowrap;}
.data-table td{padding:13px 16px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle;}
.data-table tr:last-child td{border-bottom:none;}
.data-table tbody tr{cursor:pointer;transition:background .1s;}
.data-table tbody tr:hover{background:var(--soft);}
.mono{font-family:var(--mono);}
/* STATUS BADGES */
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-family:var(--mono);letter-spacing:.04em;font-weight:400;white-space:nowrap;}
.badge-draft{background:#f1f5f9;color:#64748b;}
.badge-confirmed{background:#dbeafe;color:#1d4ed8;}
.badge-sampling{background:#f3e8ff;color:#7c3aed;}
.badge-sample_approved{background:#cffafe;color:#0e7490;}
.badge-in_production{background:#ffedd5;color:#c2410c;}
.badge-ready_to_ship{background:#fef9c3;color:#a16207;}
.badge-shipped{background:#d1fae5;color:#065f46;}
.badge-delivered{background:#bbf7d0;color:#14532d;}
.badge-closed{background:#f3f4f6;color:#374151;}
.badge-cancelled{background:#fee2e2;color:#dc2626;}
.badge-client{background:#dbeafe;color:#1d4ed8;}
.badge-factory{background:#ffedd5;color:#c2410c;}
.badge-carrier{background:#f3e8ff;color:#7c3aed;}
.badge-created{background:#f1f5f9;color:#64748b;}
.badge-in_transit{background:#dbeafe;color:#1d4ed8;}
.badge-at_origin_port,.badge-at_destination_port{background:#fef9c3;color:#a16207;}
.badge-customs{background:#f3e8ff;color:#7c3aed;}
.badge-delivered{background:#bbf7d0;color:#14532d;}
.badge-delayed,.badge-exception{background:#fee2e2;color:#dc2626;}
/* EMPTY STATE */
.empty{text-align:center;padding:64px 20px;color:var(--muted);}
.empty h3{font-family:var(--serif);font-weight:400;font-size:18px;margin-bottom:8px;color:#374151;}
.empty p{font-size:13px;line-height:1.6;}
/* MODAL */
#modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:100;align-items:center;justify-content:center;padding:20px;}
.modal-box{background:var(--card);border-radius:10px;width:100%;max-width:580px;max-height:90vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.2);}
.modal-box.modal-lg{max-width:760px;}
.modal-head{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.modal-head h3{font-family:var(--serif);font-weight:400;font-size:18px;}
.modal-close{background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted);padding:4px 8px;border-radius:4px;}
.modal-close:hover{background:var(--soft);}
.modal-body{padding:24px;overflow-y:auto;flex:1;}
.modal-foot{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;flex-shrink:0;}
/* FORM */
.form-row{margin-bottom:18px;}
.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:18px;}
.form-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:18px;}
label{display:block;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:7px;}
.form-input,.form-select,.form-textarea{width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:6px;font-family:var(--sans);font-size:13.5px;outline:none;background:#fff;color:var(--ink);transition:border-color .15s;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--ink);}
.form-textarea{resize:vertical;min-height:72px;}
.form-section{font-family:var(--mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin:24px 0 14px;padding-bottom:8px;border-bottom:1px solid var(--border);}
/* ITEMS TABLE in modal */
.items-table{width:100%;border-collapse:collapse;margin-bottom:10px;}
.items-table th{font-family:var(--mono);font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-align:left;padding:6px 8px;border-bottom:1px solid var(--border);}
.items-table td{padding:6px 8px;border-bottom:1px solid var(--border);}
.items-table td input,.items-table td select{width:100%;padding:6px 8px;border:1px solid var(--border);border-radius:4px;font-size:13px;font-family:var(--sans);background:#fff;}
.items-table .rm{color:var(--muted);background:none;border:none;cursor:pointer;font-size:16px;padding:4px 8px;}
.items-table .rm:hover{color:#dc2626;}
/* PO DETAIL */
.po-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;}
.detail-block{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:20px;}
.detail-block .blabel{font-family:var(--mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;}
.detail-block .bval{font-size:14px;font-weight:500;margin-bottom:3px;}
.detail-block .bsub{font-size:12.5px;color:var(--muted);line-height:1.6;}
.status-select{padding:7px 12px;border:1px solid var(--border);border-radius:6px;font-family:var(--sans);font-size:13px;outline:none;cursor:pointer;background:#fff;}
/* TABS */
.tabs{display:flex;gap:2px;border-bottom:1px solid var(--border);margin-bottom:20px;}
.tab{padding:10px 16px;font-size:13.5px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;color:var(--muted);transition:all .12s;}
.tab.active{color:var(--ink);border-bottom-color:var(--ink);}
/* FILTERS */
.filters{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;}
.filter-btn{padding:7px 14px;border-radius:20px;border:1px solid var(--border);background:#fff;font-size:12.5px;cursor:pointer;font-family:var(--sans);transition:all .12s;color:var(--muted);}
.filter-btn.active{background:var(--ink);color:#fff;border-color:var(--ink);}
/* LOADING */
.loading{text-align:center;padding:48px;color:var(--muted);font-size:13px;}
/* BACK BUTTON */
.back-btn{display:inline-flex;align-items:center;gap:6px;color:var(--muted);font-size:13px;cursor:pointer;margin-bottom:20px;transition:color .12s;}
.back-btn:hover{color:var(--ink);}
</style>

</head>
<body>

<div id="login-screen">
  <div class="login-card">
    <img src="data:image/png;base64," alt="King Universal">
    <h2>Sign in to Vessl</h2>
    <input id="l-email" class="login-field" type="email" placeholder="Email">
    <input id="l-pass" class="login-field" type="password" placeholder="Password">
    <button class="btn-primary" onclick="doLogin()">Sign In</button>
    <div id="l-error" class="login-error"></div>
  </div>
</div>

<div id="app" style="display:none">
  <aside id="sidebar">
    <div class="sb-logo"><img src="data:image/png;base64," alt="KUI"></div>
    <div class="sb-section">Menu</div>
    <div class="nav-link active" data-page="dashboard" onclick="navigate('dashboard')">
      <svg fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </div>
    <div class="nav-link" data-page="orders" onclick="navigate('orders')">
      <svg fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
      Purchase Orders
    </div>
    <div class="nav-link" data-page="companies" onclick="navigate('companies')">
      <svg fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      Companies
    </div>
    <div class="nav-link" data-page="products" onclick="navigate('products')">
      <svg fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
      Products
    </div>
    <div class="nav-link" data-page="shipments" onclick="navigate('shipments')">
      <svg fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      Shipments
    </div>
    <div class="sb-spacer"></div>
    <div class="sb-user">
      <span class="sb-email" id="sb-email"></span>
      <button class="btn-signout" onclick="doLogout()">Sign Out</button>
    </div>
  </aside>
  <main id="main">
    <div id="page-header">
      <h1 id="page-title"></h1>
      <div id="page-action"></div>
    </div>
    <div id="page-content"><div class="loading">Loading...</div></div>
  </main>
</div>

<div id="modal-overlay" onclick="handleOverlayClick(event)">
  <div class="modal-box" id="modal-box">
    <div id="modal-content"></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>

const SUPABASE_URL = 'https://dbqfuxuexsfpxjyfdsfh.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRicWZ1eHVleHNmcHhqeWZkc2ZoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk3NDA1MDcsImV4cCI6MjA5NTMxNjUwN30.mDB73nDh-NIb91NtP4A2ei1l5TBJLg33vxqCbeoMVg8';
const LOGO = 'data:image/png;base64,';
const SB = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY, { db: { schema: 'vessl' } });

let S = { user: null, page: 'dashboard', params: {}, filter: 'all', tab: 0 };
let modalData = {};

// ─── UTILS ───────────────────────────────────────────────────────────────────
const $id = id => document.getElementById(id);
const money = (n, c='USD') => n == null ? '—' : new Intl.NumberFormat('en-US',{style:'currency',currency:c}).format(n);
const fmtDate = s => { if (!s) return '—'; return new Date(s+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'2-digit',year:'numeric'}); };
const fmtNum = n => n == null ? '—' : new Intl.NumberFormat('en-US').format(n);
const badge = s => `<span class="badge badge-${(s||'').replace(/ /g,'_')}">${(s||'—').replace(/_/g,' ')}</span>`;
const setContent = html => { $id('page-content').innerHTML = html; };
const setTitle = (t, btns='') => { $id('page-title').textContent = t; $id('page-action').innerHTML = btns; };
const esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const now_date = () => new Date().toISOString().slice(0,10);

function navigate(page, params={}) {
  S.page = page; S.params = params;
  document.querySelectorAll('.nav-link').forEach(el => {
    const pg = page === 'order-detail' ? 'orders' : page;
    el.classList.toggle('active', el.dataset.page === pg);
  });
  renderPage();
}

async function renderPage() {
  const p = S.page;
  if (p==='dashboard') await renderDashboard();
  else if (p==='orders') await renderOrders();
  else if (p==='order-detail') await renderOrderDetail(S.params.id);
  else if (p==='companies') await renderCompanies();
  else if (p==='products') await renderProducts();
  else if (p==='shipments') await renderShipments();
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────
async function doLogin() {
  const email = $id('l-email').value.trim();
  const pass  = $id('l-pass').value;
  $id('l-error').textContent = '';
  const { error } = await SB.auth.signInWithPassword({ email, password: pass });
  if (error) $id('l-error').textContent = error.message;
}
async function doLogout() { await SB.auth.signOut(); }

function showLogin() { $id('login-screen').style.display='flex'; $id('app').style.display='none'; }
function showApp()   { $id('login-screen').style.display='none'; $id('app').style.display='flex'; $id('sb-email').textContent=S.user.email; }

// ─── DASHBOARD ───────────────────────────────────────────────────────────────
async function renderDashboard() {
  setTitle('Dashboard');
  setContent('<div class="loading">Loading...</div>');
  const [{ data: pos }, { data: cos }, { data: recent }] = await Promise.all([
    SB.from('purchase_orders').select('status'),
    SB.from('companies').select('type'),
    SB.from('purchase_orders').select('id,order_number,status,order_date,currency,factory_company_id,companies!factory_company_id(name)').order('created_at',{ascending:false}).limit(8)
  ]);
  const active = (pos||[]).filter(p=>!['closed','cancelled'].includes(p.status)).length;
  const inprod = (pos||[]).filter(p=>p.status==='in_production').length;
  const rts    = (pos||[]).filter(p=>p.status==='ready_to_ship').length;
  const clients= (cos||[]).filter(c=>c.type==='client').length;
  const rows = (recent||[]).map(p=>`
    <tr onclick="navigate('order-detail',{id:'${p.id}'})">
      <td class="mono">${esc(p.order_number||'—')}</td>
      <td>${esc(p.companies?.name||'—')}</td>
      <td>${badge(p.status)}</td>
      <td>${fmtDate(p.order_date)}</td>
    </tr>`).join('');
  setContent(`
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-label">Active Orders</div><div class="stat-value">${active}</div></div>
      <div class="stat-card"><div class="stat-label">In Production</div><div class="stat-value">${inprod}</div></div>
      <div class="stat-card"><div class="stat-label">Ready to Ship</div><div class="stat-value">${rts}</div></div>
      <div class="stat-card"><div class="stat-label">Total Clients</div><div class="stat-value">${clients}</div></div>
    </div>
    <div class="section-card">
      <div class="section-head"><h3>Recent Purchase Orders</h3></div>
      ${rows ? `<table class="data-table"><thead><tr><th>PO Number</th><th>Factory</th><th>Status</th><th>Date</th></tr></thead><tbody>${rows}</tbody></table>`
              : '<div class="empty"><h3>No orders yet</h3><p>Create your first purchase order to get started.</p></div>'}
    </div>`);
}

// ─── PURCHASE ORDERS LIST ────────────────────────────────────────────────────
const STATUSES = ['all','draft','confirmed','sampling','sample_approved','in_production','ready_to_ship','shipped','delivered','closed','cancelled'];

async function renderOrders() {
  setTitle('Purchase Orders', `<button class="btn btn-dark" onclick="showCreatePO()">+ New PO</button>`);
  setContent('<div class="loading">Loading...</div>');
  let q = SB.from('purchase_orders').select('id,order_number,status,order_date,requested_ship_date,currency,companies!factory_company_id(name)').order('created_at',{ascending:false});
  if (S.filter && S.filter!=='all') q = q.eq('status',S.filter);
  const { data, error } = await q;
  if (error) { setContent(`<div class="empty"><h3>Error loading orders</h3><p>${esc(error.message)}</p></div>`); return; }
  const filters = STATUSES.map(s=>`<button class="filter-btn ${S.filter===s?'active':''}" onclick="S.filter='${s}';renderOrders()">${s.replace(/_/g,' ')}</button>`).join('');
  const rows = (data||[]).map(p=>`
    <tr onclick="navigate('order-detail',{id:'${p.id}'})">
      <td class="mono">${esc(p.order_number||'—')}</td>
      <td>${esc(p.companies?.name||'—')}</td>
      <td>${badge(p.status)}</td>
      <td>${fmtDate(p.order_date)}</td>
      <td>${fmtDate(p.requested_ship_date)}</td>
    </tr>`).join('');
  setContent(`
    <div class="filters">${filters}</div>
    <div class="section-card">
