// ─── PO GENERATOR ────────────────────────────────────────────────────────────
async function generatePO(poId) {
  const { data, error } = await SB.rpc('po_document_json', { p_po_id: poId });
  if (error||!data) { alert('Could not generate PO document. Make sure this order has line items and a factory assigned.\n\n'+(error?.message||'')); return; }
  const win = window.open('','_blank');
  win.document.write(buildPODoc(data));
  win.document.close();
  setTimeout(()=>{ win.focus(); win.print(); },1000);
}

function buildPODoc(d) {
  const t = d.totals||{};
  const money2 = (n,c) => n==null?'—':new Intl.NumberFormat('en-US',{style:'currency',currency:c||'USD'}).format(n);
  const fdate = s => { if(!s) return '—'; return new Date(s+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'2-digit',year:'numeric'}); };
  const lines = (d.lines||[]).map(l=>`<tr>
    <td class="l"><div class="desc">${esc(l.description||'')}</div><div class="sku">${esc(l.sku||'')}</div></td>
    <td class="num">${fmtNum(l.quantity)}</td>
    <td class="num">${l.carton_count?fmtNum(l.carton_count):'—'}</td>
    <td class="num">${money2(l.unit_price,d.currency)}</td>
    <td class="num">${money2(l.line_amount,d.currency)}</td></tr>`).join('');
  const supLines = (d.supplier?.lines||[]).join('<br>');
  const shipLines = (d.ship_to?.lines||[]).join('<br>');
  return `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${esc(d.po_number||'Purchase Order')}</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Spline+Sans:wght@400;500&family=Spline+Sans+Mono:wght@400&display=swap" rel="stylesheet">
<style>
:root{--ink:#1a1d1f;--muted:#8a9097;--soft:#c9ccce;--hair:#ececec;}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{background:#fff;color:var(--ink);font-family:'Spline Sans',sans-serif;-webkit-font-smoothing:antialiased;font-size:13px;}
.page{max-width:8.5in;margin:0 auto;padding:0.9in 0.9in 0.8in;min-height:11in;}
.lbl{font-family:'Spline Sans Mono',monospace;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.num{font-family:'Spline Sans Mono',monospace;}
.head{display:flex;justify-content:space-between;align-items:center;margin-bottom:60px;}
.logo{height:56px;}
.doctitle{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:52px;}
h1{font-family:'Fraunces',serif;font-weight:400;font-size:30px;}
.po .v{font-family:'Spline Sans Mono',monospace;font-size:15px;margin-top:5px;text-align:right;}
.parties{display:grid;grid-template-columns:1fr 1fr;gap:56px;margin-bottom:46px;}
.party .lbl{margin-bottom:11px;}
.party .name{font-size:14px;font-weight:500;margin-bottom:5px;}
.party .body{font-size:12px;line-height:1.75;color:var(--muted);}
.terms{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;padding-top:22px;border-top:1px solid var(--hair);margin-bottom:50px;}
.terms .t .lbl{margin-bottom:7px;}
.terms .t .v{font-size:13px;font-weight:500;}
table{width:100%;border-collapse:collapse;}
thead th{font-family:'Spline Sans Mono',monospace;font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);text-align:right;font-weight:400;padding:0 0 14px;}
thead th.l{text-align:left;}
tbody td{font-size:12.5px;padding:18px 0;border-top:1px solid var(--hair);text-align:right;vertical-align:top;}
tbody td.l{text-align:left;padding-right:24px;}
.desc{font-weight:500;font-size:13px;}.sku{font-family:'Spline Sans Mono',monospace;font-size:10px;color:var(--soft);margin-top:4px;}
.foot{display:grid;grid-template-columns:1fr 280px;gap:60px;margin-top:46px;}
.notes .lbl{margin-bottom:12px;}.notes p{font-size:11.5px;line-height:1.8;color:var(--muted);}
.trow{display:flex;justify-content:space-between;padding:9px 0;font-size:12.5px;}
.trow .k{color:var(--muted);}.trow .v{font-family:'Spline Sans Mono',monospace;}
.trow.note .k,.trow.note .v{color:var(--soft);font-style:italic;}
.grand{display:flex;justify-content:space-between;padding:16px 0 0;margin-top:8px;border-top:1px solid var(--ink);}
.grand .k{font-family:'Fraunces',serif;font-size:14px;}.grand .v{font-family:'Spline Sans Mono',monospace;font-size:19px;}
.dep{display:flex;justify-content:space-between;padding-top:12px;font-size:11.5px;color:var(--muted);}
.dep .v{font-family:'Spline Sans Mono',monospace;}
.sign{display:grid;grid-template-columns:1fr 1fr;gap:56px;margin-top:80px;}
.sline{border-top:1px solid var(--soft);padding-top:8px;}
.pagefoot{margin-top:54px;display:flex;justify-content:space-between;font-family:'Spline Sans Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--soft);}
@media print{@page{size:letter;margin:0;}.page{padding:0.85in 0.9in;}}
</style></head><body>
<div class="page">
  <div class="head"><img class="logo" src="${LOGO}" alt="King Universal"></div>
  <div class="doctitle">
    <h1>Purchase Order</h1>
    <div class="po"><div class="lbl">PO Number</div><div class="v">${esc(d.po_number||'—')}</div></div>
  </div>
  <div class="parties">
    <div class="party"><div class="lbl">Supplier</div><div class="name">${esc(d.supplier?.name||'—')}</div><div class="body">${d.supplier?.contact?'Attn: '+esc(d.supplier.contact)+'<br>':''}${supLines}${d.supplier?.email?'<br>'+esc(d.supplier.email):''}</div></div>
    <div class="party"><div class="lbl">Ship To</div><div class="name">${esc(d.ship_to?.name||'—')}</div><div class="body">${shipLines}</div></div>
  </div>
  <div class="terms">
    <div class="t"><div class="lbl">Order Date</div><div class="v">${fdate(d.order_date)}</div></div>
    <div class="t"><div class="lbl">Ship By</div><div class="v">${fdate(d.requested_ship_date)}</div></div>
    <div class="t"><div class="lbl">Incoterm</div><div class="v">${esc(d.incoterm||'—')}</div></div>
    <div class="t"><div class="lbl">Payment</div><div class="v">${esc(d.payment_terms||'—')}</div></div>
  </div>
  <table>
    <thead><tr><th class="l">Item</th><th>Qty</th><th>Cartons</th><th>Unit</th><th>Amount</th></tr></thead>
    <tbody>${lines}</tbody>
  </table>
  <div class="foot">
    <div class="notes"><div class="lbl">Notes</div><p>${esc(d.notes||'')}</p>${t.total_cartons?`<div class="lbl" style="margin-top:22px;margin-bottom:8px">Logistics</div><p>${fmtNum(t.total_cartons)} cartons · ${t.total_cbm} CBM · ${fmtNum(t.total_gross_weight_kg)} kg gross</p>`:''}
    </div>
    <div>
      <div class="trow"><span class="k">Goods subtotal</span><span class="v">${money2(t.subtotal,d.currency)}</span></div>
      ${t.mold_fee?`<div class="trow"><span class="k">Tooling / mold</span><span class="v">${money2(t.mold_fee,d.currency)}</span></div>`:''}
      ${t.sample_fee?`<div class="trow note"><span class="k">Sample fee (sep.)</span><span class="v">${money2(t.sample_fee,d.currency)}</span></div>`:''}
      <div class="grand"><span class="k">Total — ${esc(d.currency||'USD')}</span><span class="v">${money2(t.grand_total,d.currency)}</span></div>
      ${t.deposit_amount?`<div class="dep"><span>${d.deposit_percent}% deposit</span><span class="v">${money2(t.deposit_amount,d.currency)}</span></div>`:''}
    </div>
  </div>
  <div class="sign">
    <div><div class="sline"><div class="lbl">Authorized — King Universal Inc.</div></div></div>
    <div><div class="sline"><div class="lbl">Accepted — Supplier</div></div></div>
  </div>
  <div class="pagefoot"><span>King Universal Inc.</span><span>${esc(d.po_number||'')}</span></div>
</div>
</body></html>`;
}

// ─── INIT ────────────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', async () => {
  const { data: { session } } = await SB.auth.getSession();
  if (session) { S.user = session.user; showApp(); navigate('dashboard'); }
  else { showLogin(); }
  SB.auth.onAuthStateChange((event, session) => {
    if (event==='SIGNED_IN')  { S.user=session.user; showApp(); navigate('dashboard'); }
    if (event==='SIGNED_OUT') { S.user=null; showLogin(); }
  });
  $id('l-pass').addEventListener('keydown', e => { if (e.key==='Enter') doLogin(); });
});

</script>
</body>
</html>
